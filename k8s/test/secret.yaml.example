# Copy this file to secret.yaml and fill in real values.
# secret.yaml is gitignored — never commit it.
#
# Plugin URLs use cluster-internal DNS (service.namespace.svc.cluster.local).
# API keys come from the homelab SOPS secret in kubernetes/apps/media/media-secrets/.
# Decrypt with: SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt sops -d secret.sops.yaml
#
# Jellyfin note: the optional `username` field accepts a Jellyfin user ID (hex string),
# not a display name. Retrieve it from the Jellyfin admin UI → Users → <user> → URL.
apiVersion: v1
kind: Secret
metadata:
  name: mortar-config
  namespace: mortar-test
stringData:
  config.yaml: |
    server:
      port: 3000

    plugins:
      - id: jellyseerr
        type: jellyseerr
        url: http://seerr.media.svc.cluster.local
        api_key: REPLACE_WITH_SEERR_API_KEY

      - id: jellyfin
        type: jellyfin
        url: http://jellyfin.media.svc.cluster.local
        api_key: REPLACE_WITH_JELLYFIN_API_KEY

      - id: sabnzbd
        type: sabnzbd
        url: http://sabnzbd.media.svc.cluster.local
        api_key: REPLACE_WITH_SABNZBD_API_KEY

      - id: sonarr
        type: sonarr
        url: http://sonarr.media.svc.cluster.local
        api_key: REPLACE_WITH_SONARR_API_KEY

      - id: radarr
        type: radarr
        url: http://radarr.media.svc.cluster.local
        api_key: REPLACE_WITH_RADARR_API_KEY
